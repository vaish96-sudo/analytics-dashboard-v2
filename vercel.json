{
  "buildCommand": "node ./node_modules/vite/bin/vite.js build",
  "rewrites": [
    { "source": "/auth/callback", "destination": "/index.html" },
    { "source": "/reset-password", "destination": "/index.html" },
    { "source": "/instant", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/data/refresh-sheets",
      "schedule": "0 6 * * *"
    }
  ]
}