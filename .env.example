# ============================================================
# Meuris Analytics v2 — Environment Variables
# ============================================================
# Copy this to .env.local for local development
# Add these to Vercel Environment Variables for production

# --- Supabase (REQUIRED) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- Anthropic AI ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Google OAuth (for Sheets integration) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# --- App URL (for password reset links, email links) ---
APP_URL=https://analytics-dashboard-v2-zeta.vercel.app

# --- Stripe (for Pro subscriptions) ---
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Create products/prices in Stripe Dashboard, then set the Pro monthly price ID:
# VITE_STRIPE_PRO_PRICE_ID=price_xxx (optional, can also be set in code)

# --- Resend (for transactional emails) ---
RESEND_API_KEY=re_your-resend-api-key
