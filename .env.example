# ============================================================
# Northern Bird Analytics v2 — Environment Variables
# ============================================================
# Copy this to .env.local for local development
# Add these to Vercel Environment Variables for production

# --- Supabase (REQUIRED for v2) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- Anthropic AI (existing) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Google OAuth (existing — now only for Sheets, not login) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# --- App URL (for password reset links) ---
APP_URL=https://northernbird-analytics.vercel.app
